# ─────────────────────────────────────────────────────
#  SENTINEL — Environment Variables
#  Copy this file to .env.local and fill in your keys.
#  All "FREE" entries work without a paid account.
# ─────────────────────────────────────────────────────

# ── FREE APIs (no key needed) ──────────────────────
# These are hardcoded in the API routes — nothing to configure.
# USGS Earthquake feed: https://earthquake.usgs.gov/earthquakes/feed/
# NASA EONET events:    https://eonet.gsfc.nasa.gov/api/v3/events
# CoinGecko free tier:  https://api.coingecko.com/api/v3
# RSS2JSON (news proxy):https://api.rss2json.com/v1/api.json

# ── PHASE 2: PAID / KEY-GATED APIs ────────────────
# Uncomment and fill when upgrading to live market data.

# Polygon.io — live US stocks, forex, indices ($29/mo Starter)
# POLYGON_API_KEY=your_polygon_key_here

# Finnhub — real-time quotes + earnings calendar ($49/mo Premium)
# FINNHUB_API_KEY=your_finnhub_key_here

# Anthropic Claude — AI daily briefings (pay-per-token)
# ANTHROPIC_API_KEY=your_anthropic_key_here

# ── AUTH (Clerk — free up to 10k MAU) ─────────────
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
# NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ── DATABASE (Supabase — free tier) ───────────────
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ── CACHE (Upstash Redis — free tier 10k req/day) ─
# UPSTASH_REDIS_REST_URL=https://...upstash.io
# UPSTASH_REDIS_REST_TOKEN=AX...

# ── EMAIL (Resend — free 3k/mo) ──────────────────
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=alerts@yourdomain.com

# ── APP SETTINGS ─────────────────────────────────
NEXT_PUBLIC_APP_NAME=SENTINEL
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
